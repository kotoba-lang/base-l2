{
  "name": "@etzhayyim/base-l2",
  "version": "0.1.0-alpha",
  "description": "Base L2 MST-root anchor client (viem) + ERC-4337 sponsored-write helper. Relocated from etzhayyim/root:20-actors/etzhayyim-sdk/src/{l2,paymaster}.ts per the kotoba-lang library-placement rule (ADR-2606302300). Provider-agnostic -- no bundler/paymaster vendor binding.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:kotoba-lang/base-l2.git"
  },
  "homepage": "https://etzhayyim.com",
  "keywords": [
    "kotoba-lang",
    "base",
    "l2",
    "viem",
    "erc-4337",
    "paymaster"
  ]
}
